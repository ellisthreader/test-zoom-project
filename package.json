{
  "name": "relayclarity-deployment-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "client": "vite --host 0.0.0.0 --strictPort",
    "server": "tsx server/start.tsx",
    "start": "npm run dev",
    "dev": "node scripts/dev.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "video:preview": "remotion studio remotion/index.tsx",
    "video:render": "remotion render remotion/index.tsx RelayClarityLaunchVideo public/relayclarity-launch-video.mp4 --codec=h264",
    "test": "tsx --test src/business-type-matcher.test.ts server/ai/client.test.tsx server/ai/orchestrator.test.tsx server/voice/elevenlabs.test.tsx server/zoom/webhook.test.tsx server/adapters/integrations.test.tsx server/telephony/audio-store.test.tsx",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.478",
    "@remotion/renderer": "^4.0.478",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "openai": "^6.42.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remotion": "^4.0.478"
  }
}
